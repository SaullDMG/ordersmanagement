@model IEnumerable<OrdersManagement.Models.Cliente>
@{

}

<div class="mt-3 row">
    <div class="col-sm-12 col-md-6">
        <h4>Registro de Clientes</h4>
    </div>
    <div class="col-sm-12 col-md-6 text-end">
        <a class="btn btn-sm btn-outline-primary" asp-controller="Clientes" asp-action="Create">
            Crear Cliente
        </a>
    </div>
    
    <div class="col-sm-12">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nombre</th>
                    <th>Dirección</th>
                    <th align="center">Teléfono</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (Cliente item in Model)
                {
                    <tr>
                        <td scope="row">@item.Id</td>
                        <td>@item.Nombre</td>
                        <td>@item.Direccion</td>
                        <td align="center">$@item.Telefono</td>
                       
                    </tr>
                    
                }
            </tbody>
        </table>
    </div>
</div>